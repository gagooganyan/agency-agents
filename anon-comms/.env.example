# ─── Telegram ───────────────────────────────────────────────
# Получи токен у @BotFather
BOT_TOKEN=your_bot_token_here

# ─── Telnyx ─────────────────────────────────────────────────
# API Keys → https://portal.telnyx.com/#/app/api-keys
TELNYX_API_KEY=KEY0...

# Messaging → Profiles → Create profile
# Webhook URL: https://YOUR_DOMAIN/webhooks/sms
TELNYX_MESSAGING_PROFILE_ID=40019999-0000-0000-0000-000000000000

# Voice → TeXML Apps → Create app
# Voice Request URL: https://YOUR_DOMAIN/webhooks/voice/inbound
# Call Control Webhooks URL: https://YOUR_DOMAIN/webhooks/voice/call-control
TELNYX_VOICE_CONNECTION_ID=2294000000000000000

# ─── Server ─────────────────────────────────────────────────
# Public URL вашего сервера (ngrok / VPS)
WEBHOOK_BASE_URL=https://your-server.com

PORT=8000
